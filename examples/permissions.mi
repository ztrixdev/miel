#Import "std/fs"

func ReadFileToString :: callable(path: strbuf): strbuf @fs.FsRead {
    ;; read file
}

proc Main :: callable() @Root {
    acquire fs.FsRead from Root
    defer release fs.FsRead ;; will throw a compile error if fs.FsRead isn't already in scope

    contents := ReadFileToString("config.mi") ;; correct while fs.FsRead is in-scope and acquired
}